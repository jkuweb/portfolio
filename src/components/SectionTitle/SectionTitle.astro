---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<h2 class="relative mt-2.5 mb-10 grid grid-cols-[auto_1fr_2fr] items-center">
	{title}
</h2>
<style>
	h2 {
		counter-increment: section 1;
		font-size: clamp(26px, 5vw, 32px);
		white-space: nowrap;
		&:before {
			content: '0' counter(section) '.';
			position: relative;
			color: var(--color-secondary);
			font-size: clamp(16px, 3vw, 20px);
			font-weight: 400;
			margin-right: 5px;
			top: 4px;
		}
		&::after {
			content: '';
			display: block;
			width: 100%;
			height: 1px;
			background-color: var(--lightest-navy);
		}
	}
</style>
