---
import Header from '@/components/Header/Header.astro';
import Footer from '@/components/Footer/Footer.astro';
import SocialMedia from '@/components/SocialMedia/SocialMedia.astro';
import Loader from '@/components/Loader/Loader.astro';
import '@fontsource/space-mono/400.css';
import '@fontsource/space-mono/700.css';
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	canonical?: string;
	image?: string;
	type?: 'website' | 'article';
	article?: {
		publishedTime?: string;
		modifiedTime?: string;
		author?: string;
	};
}

const {
	title,
	description = 'Portfolio personal de Joseba Querejeta - Desarrollador Web Full Stack especializado en React, Astro y TypeScript.',
	canonical,
	image = '/og-image.png',
	type = 'website',
	article,
} = Astro.props;

const siteTitle = title
	? `${title} | Joseba Querejeta`
	: 'Joseba Querejeta | Desarrollador Web Full Stack';
const siteUrl = 'https://josebaquerejeta.dev';
const currentUrl = canonical ? `${siteUrl}${canonical}` : Astro.url.href;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />

		<title>{siteTitle}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={currentUrl} />
		<meta
			name="robots"
			content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
		/>

		<meta property="og:type" content={type} />
		<meta property="og:site_name" content="Joseba Querejeta" />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={siteTitle} />
		<meta property="og:locale" content="es_ES" />

		{
			article?.publishedTime && (
				<meta
					property="article:published_time"
					content={article.publishedTime}
				/>
			)
		}
		{
			article?.modifiedTime && (
				<meta property="article:modified_time" content={article.modifiedTime} />
			)
		}
		{
			article?.author && (
				<meta property="article:author" content={article.author} />
			)
		}

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={siteTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#38ffa9" />

		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="referrer" content="strict-origin-when-cross-origin" />
		<meta http-equiv="X-Content-Type-Options" content="nosniff" />
		<meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()" />
		<meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'self'; base-uri 'self'; form-action 'self'" />
		<meta http-equiv="X-Frame-Options" content="DENY" />

		<script
			type="application/ld+json"
			set:html={JSON.stringify({
				'@context': 'https://schema.org',
				'@type': 'Person',
				name: 'Joseba Querejeta',
				url: siteUrl,
				jobTitle: 'Desarrollador Web Full Stack',
				sameAs: [
					'https://github.com/josebaquerejeta',
					'https://linkedin.com/in/josebaquerejeta',
				],
			}).replace(/</g, '\\u003c')}
		/>
	</head>
	<body>
		<div aria-live="polite" aria-atomic="true" class="sr-only" id="announcer">
		</div>
		<Loader />
		<a
			href="#mainContent"
			class="skip-link absolute -top-10 left-0 z-50 bg-black px-4 py-2 font-bold text-white focus:top-0"
		>
			Saltar al contenido
		</a>
		<Header />
		<div id="overlay">
			<main
				id="mainContent"
				class="max-w-main m-auto px-3.5 sm:px-12.5 md:px-37.5"
			>
				<slot />
				<SocialMedia />
			</main>
			<Footer />
		</div>

		<script is:inline>
			const announcer = document.getElementById('announcer');
			const observer = new MutationObserver(() => {
				const message = announcer?.getAttribute('data-announce');
				if (message) {
					announcer.textContent = message;
					setTimeout(() => {
						announcer.textContent = '';
					}, 1000);
				}
			});
			observer.observe(announcer, {
				attributes: true,
				attributeFilter: ['data-announce'],
			});
		</script>
		<script is:inline>
			window.addEventListener('load', () => {
				const alreadyVisit = localStorage.getItem('alreadyVisit');

				const loader = document.getElementById('loader');
				const overlay = document.getElementById('overlay');

				if (!loader || !overlay) return;

				function triggerAnimations() {
					document.body.classList.add('loaded');
				}

				if (!alreadyVisit) {
					setTimeout(() => {
						loader.style.opacity = '0';
						loader.style.transition = 'opacity 0.5s';
						setTimeout(() => {
							loader.remove();
							overlay.classList.remove('hidden');
							triggerAnimations();
						}, 500);
						localStorage.setItem('alreadyVisit', 'true');
					}, 3000);
				} else {
					loader.remove();
					overlay.classList.remove('hidden');
					requestAnimationFrame(() => triggerAnimations());
				}

				const sections = document.querySelectorAll(
					'.about, #contact, #experience',
				);

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add('fade-in-section');
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.1 },
				);

				sections.forEach((section) => observer.observe(section));
			});
		</script>
	</body>
</html>
<style>
	.skip-link {
		transition: top 0.3s ease-in-out;
	}

	.skip-link:focus {
		top: 0;
		background-color: #38ffa9;
		color: #000;
	}
	.blur-effect {
		filter: blur(5px);
		position: relative;
		z-index: -1;
		position: fixed;
	}
</style>
